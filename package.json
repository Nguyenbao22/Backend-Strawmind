{
  "name": "strawmind-iot-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "client": "vite --host 0.0.0.0",
    "server": "node server/index.js",
    "start": "node server/index.js",
    "dev": "concurrently \"npm:server\" \"npm:client\"",
    "mobile": "npm --prefix mobile start",
    "sim": "node tools/device-simulator.js",
    "ai:sim": "node tools/ai-detection-simulator.js",
    "mqtt:sim": "node tools/mqtt-device-simulator.js",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "@supabase/supabase-js": "^2.86.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "lucide-react": "^0.468.0",
    "mqtt": "^5.15.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "vite": "^7.2.7",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
